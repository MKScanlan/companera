function getRoleGuidance(role) {
  const guides = {
    teacher: `The user is a TEACHER. Anchor all conversation in classroom-level practice. Help them connect pedagogies of character formation to daily instructional decisions: how virtues are cultivated in circle time, how identity affirmation shows up in curriculum, how civic mindedness is practiced across languages. Use concrete, classroom-grounded language and draw on specific examples from the four focal schools. Ask about their students, grade level, language model, and school context.`,

    coach: `The user is an INSTRUCTIONAL COACH or MENTOR. Help them think about how to support teachers in noticing, naming, and enacting these pedagogies. Focus on professional learning cycles, classroom observations, and how to surface character formation in coaching conversations. Draw on examples of adult enactment from the schools. Ask about the teachers they work with and the patterns they observe in classrooms and school culture.`,

    administrator: `The user is a SCHOOL ADMINISTRATOR (principal, AP, or district leader). Help them think at the systems level: school culture, structures, hiring, professional development, and how the school's mission is embodied institutionally. Draw on school-wide structures from the case — behavioral plans, awards, campaigns, faculty meeting practices, staff training. Connect to the Jubilee Centre's emphasis that strong, committed leadership is essential to embedding character education. Ask about their school's current culture, challenges, and goals.`,

    'graduate student': `The user is a GRADUATE STUDENT, likely in educational leadership, Catholic education, bilingual education, or a related field. Engage them academically and theoretically. Make connections to research frameworks — the Jubilee Centre virtue typology, sociocultural competence (Howard et al., 2022), Catholic Social Teaching, whole-child education. Invite critical analysis and scholarly questioning. Ask about their research interests, theoretical frameworks, and how the case connects to their coursework or inquiry project.`
  };
  return guides[role] || guides['teacher'];
}


async function sendMessage() {
  const input = document.getElementById('user-input');
  const text = input.value.trim();
  if (!text || isLoading) return;
  if (!apiKey) { showToast('Please enter your API key first.'); return; }

  input.value = '';
  input.style.height = 'auto';
  addMessage('user', text);
  conversationHistory.push({ role: 'user', content: text });

  if (conversationHistory.filter(m => m.role === 'user').length === 1) {
    document.getElementById('quick-prompts').style.display = 'none';
  }

  tryAdvancePhase();
  showTyping();
  isLoading = true;
  document.getElementById('send-btn').disabled = true;

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5',
        max_tokens: 1000,
        system: buildSystemPrompt(currentRole, currentPhase),
        messages: conversationHistory
      })
    });

    const data = await resp.json();
    hideTyping();

    if (data.error) {
      const msg = data.error.message || 'API error';
      showToast(msg.length > 80 ? msg.slice(0, 80) + '…' : msg);
      conversationHistory.pop();
    } else {
      const reply = data.content[0].text;
      addMessage('ai', reply);
      conversationHistory.push({ role: 'assistant', content: reply });
    }
  } catch (err) {
    hideTyping();
    showToast('Connection error. Please check your network and try again.');
    conversationHistory.pop();
  }

  isLoading = false;
  document.getElementById('send-btn').disabled = false;
}

